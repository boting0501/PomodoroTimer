<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 分析頁面標題 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="分析頁面"
            android:textSize="24sp"
            android:textColor="#FF6347"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="16dp" />

        <!-- 今日番茄鐘數量 -->
        <TextView
            android:id="@+id/today_tomato_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="今日番茄鐘數量：0"
            android:textSize="18sp"
            android:textColor="#333"
            android:layout_marginBottom="16dp" />

        <!-- 時長區塊 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- 今日時長 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FADADD"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日時長"
                    android:textSize="18sp"
                    android:textColor="#FF6347" />

                <TextView
                    android:id="@+id/today_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 分鐘"
                    android:textSize="16sp"
                    android:textColor="#333" />
            </LinearLayout>

            <!-- 月度時長 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FADADD"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="月度時長"
                    android:textSize="18sp"
                    android:textColor="#FF6347" />

                <TextView
                    android:id="@+id/monthly_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 分鐘"
                    android:textSize="16sp"
                    android:textColor="#333" />
            </LinearLayout>
        </LinearLayout>

        <!-- 新增番茄鐘分類區 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="番茄鐘分類"
            android:textSize="20sp"
            android:textColor="#FF6347"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FADADD"
            android:padding="16dp"
            android:layout_marginTop="8dp">

            <!-- 類別 1：學習 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="學習"
                    android:textSize="16sp"
                    android:textColor="#333" />

                <TextView
                    android:id="@+id/study_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 次"
                    android:textSize="16sp"
                    android:textColor="#333" />
            </LinearLayout>

            <!-- 類別 2：工作 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="工作"
                    android:textSize="16sp"
                    android:textColor="#333" />

                <TextView
                    android:id="@+id/work_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 次"
                    android:textSize="16sp"
                    android:textColor="#333" />
            </LinearLayout>

            <!-- 類別 3：休息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="休息"
                    android:textSize="16sp"
                    android:textColor="#333" />

                <TextView
                    android:id="@+id/rest_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 次"
                    android:textSize="16sp"
                    android:textColor="#333" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
